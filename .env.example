# =============================================================================
# NEXUS — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# --- API Server ---
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# --- Database ---
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# --- Redis (queues, caching, realtime baselines) ---
REDIS_URL=redis://localhost:6379

# --- JWT Auth (CHANGE IN PRODUCTION — min 32 chars) ---
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_RPM_DEFAULT=300

# --- AI / LLM (set LLM_PROVIDER=openai and add key for live Copilot) ---
LLM_PROVIDER=none
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Object Storage (evidence, reports) ---
S3_BUCKET=
S3_REGION=us-east-1

# --- Webhooks ---
WEBHOOK_SIGNING_SECRET=

# --- Demo Login ---
# Email: amelia.lee@acme.federal
# Password: NexusDemo2024!
